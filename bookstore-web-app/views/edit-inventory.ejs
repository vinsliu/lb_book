<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Edit Book</title>
    <link rel="stylesheet" href="/stylesheets/style.css" />
  </head>

  <body>
    <div class="container">
      <h1>Edit Book</h1>

      <form method="POST" action="/inventory/edit/<%= book.id %>">
        <div>
          <label>Title</label>
          <input type="text" name="title" value="<%= book.title %>" required />
        </div>

        <div>
          <label>Author</label>
          <input
            type="text"
            name="author"
            value="<%= book.author %>"
            required
          />
        </div>

        <div>
          <label>Price</label>
          <input
            type="number"
            name="price"
            step="0.01"
            value="<%= book.price %>"
            required
          />
        </div>

        <div>
          <label>Stock</label>
          <input
            type="number"
            name="stock"
            value="<%= book.stock %>"
            required
          />
        </div>

        <button type="submit">Update</button>
      </form>

      <a href="/inventory">← Back</a>
    </div>
  </body>
</html>
