<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Edit Order</title>
    <link rel="stylesheet" href="/stylesheets/style.css" />
  </head>

  <body>
    <div class="container">
      <h1>Edit Order</h1>

      <form method="POST" action="/orders/edit/<%= order.id %>">
        <div>
          <label>Customer Name</label>
          <input
            type="text"
            name="customerName"
            value="<%= order.customerName %>"
          />
        </div>

        <div>
          <label>Order Date</label>
          <input
            type="datetime-local"
            name="orderDate"
            value="<%= new Date(order.orderDate).toISOString().slice(0,16) %>"
          />
        </div>

        <div>
          <label>Total Amount</label>
          <input
            type="number"
            name="totalAmount"
            value="<%= order.totalAmount %>"
          />
        </div>

        <div>
          <label>Status</label>
          <input type="text" name="status" value="<%= order.status %>" />
        </div>

        <button type="submit">Update</button>
      </form>

      <a href="/orders">← Back</a>
    </div>
  </body>
</html>
